# Kuwait Alyoum / STC Tender Platform — VPS environment template
# Copy to /opt/tender-platform/.env on the VPS and fill in REAL values there.
# NEVER commit the real .env (it is gitignored).

# ── AI providers (REQUIRED) ─────────────────────────────────────────────────
# Claude does OCR, summarization, extraction and Q&A.
ANTHROPIC_API_KEY=
# Voyage AI generates the legal-document embeddings (voyage-law-2).
VOYAGE_API_KEY=

# ── Browserless (OPTIONAL — PAID FALLBACK ONLY) ─────────────────────────────
# Leave blank to disable. The free local Playwright/Chromium path runs first;
# Browserless is only used when the local screenshot fails.
BROWSERLESS_API_KEY=

# ── Database (REQUIRED) ─────────────────────────────────────────────────────
# Phase 1 default: keep the existing managed Postgres (e.g. Neon) connection
# string here. Must be a pgvector-enabled Postgres.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
# To self-host instead, start the stack with `--profile localdb` and use:
#   DATABASE_URL=postgresql://tender:CHANGE_ME@postgres:5432/tender
# and set the matching POSTGRES_* vars below.
POSTGRES_USER=tender
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=tender

# ── Cache (OPTIONAL) ────────────────────────────────────────────────────────
# Provided by the bundled redis service. The app runs fine without it.
REDIS_URL=redis://redis:6379/0

# ── Cron / job protection (REQUIRED) ────────────────────────────────────────
# Bearer token guarding /api/cron/* endpoints. Generate a long random value.
CRON_SECRET=

# ── Kuwait Al-Yawm gazette login (REQUIRED for scraping) ────────────────────
KUWAIT_ALYOM_USERNAME=
KUWAIT_ALYOM_PASSWORD=

# ── Observability (OPTIONAL) ────────────────────────────────────────────────
SENTRY_DSN=

# ── Cost-control flags (keep as-is unless you know why) ─────────────────────
# Legacy OpenAI scrape/processing path — keep OFF.
ENABLE_LEGACY_OPENAI_PIPELINE=false
# Legacy Celery beat schedule — keep OFF (weekly scrape runs via systemd timer).
ENABLE_CELERY_BEAT=false
# Per-call provider usage logging into usage_logs (powers /api/cron/usage-report).
ENABLE_USAGE_LOGGING=true
# Hard ceiling on tenders AI-processed per scrape run.
MAX_TENDERS_PER_RUN=120

# OpenAI is deprecated and must remain unset unless you deliberately re-enable
# the legacy pipeline above.
# OPENAI_API_KEY=
